---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.name }}</title>
  <subtitle>News and updates from Fertility Research UK</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}/" rel="alternate" type="text/html"/>
  <updated>{% if collections.news.length %}{{ (collections.news | last).date | isoDate }}T00:00:00Z{% else %}2026-01-01T00:00:00Z{% endif %}</updated>
  <id>{{ site.url }}/</id>
  <author>
    <name>{{ site.name }}</name>
  </author>
  {% for post in collections.news | reverse %}
  <entry>
    <title>{{ post.data.headline }}</title>
    <link href="{{ site.url }}/news/" rel="alternate" type="text/html"/>
    <id>{{ site.url }}/news/#{{ post.data.headline | slugify }}</id>
    <published>{{ post.date | isoDate }}T00:00:00Z</published>
    <updated>{{ post.date | isoDate }}T00:00:00Z</updated>
    <summary>{{ post.data.summary }}</summary>
    <content type="html">{{ post.templateContent | safe }}</content>
  </entry>
  {% endfor %}
</feed>
