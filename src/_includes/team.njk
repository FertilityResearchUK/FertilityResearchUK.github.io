---
layout: base.njk
---
    <!-- ======== TEAM HERO ======== -->
    <section class="hero">
      <div class="container">
        <h1>{{ hero_title }}</h1>
        <p class="tagline">{{ hero_tagline }}</p>
      </div>
    </section>

    <!-- ======== TRUSTEES ======== -->
    <section class="section section--alt" id="trustees">
      <div class="container">
        <div class="section__header">
          <h2>Trustees</h2>
          <p>{{ trustees_intro }}</p>
        </div>

        <div class="people-grid people-grid--profiles people-grid--trustees">
          {% for person in collections.trustees %}
          <article class="person-card person-card--portrait">
            <div class="person-card__media">
              {% if person.data.photo %}
              <img src="{{ person.data.photo }}" alt="" loading="lazy" decoding="async">
              {% else %}
              <div class="person-card__placeholder" aria-hidden="true">{{ person.data.name | initials }}</div>
              {% endif %}
            </div>
            <div class="person-card__body">
              <div class="person-card__name-row">
                <h3 class="person-card__name">{{ person.data.name }}</h3>
                {% if person.data.linkedin %}<a href="{{ person.data.linkedin }}" class="linkedin-link" target="_blank" rel="noopener" aria-label="{{ person.data.name }} on LinkedIn"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></a>{% endif %}
              </div>
              {% if person.data.role %}<p class="person-card__role">{{ person.data.role }}</p>{% endif %}
              {% if person.data.bio or person.data.quote %}
              <details class="person-card__details">
                <summary class="person-card__summary">
                  <span>Read more</span>
                  <span class="person-card__chev" aria-hidden="true"></span>
                </summary>
                <div class="person-card__expand">
                  {% if person.data.bio %}<p class="person-card__bio">{{ person.data.bio }}</p>{% endif %}
                  {% if person.data.quote %}<p class="person-card__quote">&ldquo;{{ person.data.quote }}&rdquo;</p>{% endif %}
                </div>
              </details>
              {% endif %}
            </div>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <!-- ======== TEAM MEMBERS ======== -->
    <section class="section section--team-members" id="team-members">
      <div class="container">
        <div class="section__header section__header--team">
          <h2>Who We Are</h2>
          <p class="section__deck section__deck--tight">{{ team_intro }}</p>
        </div>

        <div class="people-grid people-grid--profiles people-grid--who-we-are">
          {% for person in collections.teamMembers %}
          <article class="person-card person-card--portrait">
            <div class="person-card__media">
              {% if person.data.photo %}
              <img src="{{ person.data.photo }}" alt="" loading="lazy" decoding="async">
              {% else %}
              <div class="person-card__placeholder" aria-hidden="true">{{ person.data.name | initials }}</div>
              {% endif %}
            </div>
            <div class="person-card__body">
              <div class="person-card__name-row">
                <h3 class="person-card__name">{{ person.data.name }}</h3>
                {% if person.data.linkedin %}<a href="{{ person.data.linkedin }}" class="linkedin-link" target="_blank" rel="noopener" aria-label="{{ person.data.name }} on LinkedIn"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></a>{% endif %}
              </div>
              {% if person.data.badge %}<p class="person-card__badge">{{ person.data.badge }}</p>{% endif %}
              {% if person.data.bio or person.data.quote %}
              <details class="person-card__details">
                <summary class="person-card__summary">
                  <span>Read more</span>
                  <span class="person-card__chev" aria-hidden="true"></span>
                </summary>
                <div class="person-card__expand">
                  {% if person.data.bio %}<p class="person-card__bio">{{ person.data.bio }}</p>{% endif %}
                  {% if person.data.quote %}<p class="person-card__quote">&ldquo;{{ person.data.quote }}&rdquo;</p>{% endif %}
                </div>
              </details>
              {% endif %}
            </div>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <!-- ======== SCIENTIFIC ADVISORY GROUP ======== -->
    <section class="section section--alt" id="advisors">
      <div class="container">
        <div class="section__header">
          <h2>Scientific &amp; Clinical Advisory Group</h2>
          <p>{{ advisors_intro }}</p>
        </div>

        <div class="card-grid card-grid--3" style="max-width:800px; margin:0 auto;">
          {% for card in advisor_cards %}
          <div class="card card--cue{% if loop.index0 % 2 == 1 %} card--cue-accent{% endif %}">
            <h3>{{ card.title }}</h3>
            <p>{{ card.description }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <!-- ======== VOLUNTEERS ======== -->
    <section class="section" id="volunteers">
      <div class="container">
        <div class="section__header">
          <h2>Volunteers</h2>
          <p>{{ volunteers_intro }}</p>
        </div>

        <div class="card-grid card-grid--3" style="max-width:800px; margin:0 auto;">
          {% for card in volunteer_cards %}
          <div class="card card--cue{% if loop.index0 % 2 == 1 %} card--cue-accent{% endif %}">
            <h3>{{ card.title }}</h3>
            <p>{{ card.description }}</p>
          </div>
          {% endfor %}
        </div>

        <div class="text-center mt-4">
          <p class="text-muted mb-2">We welcome volunteers from across the UK — remote or in person.</p>
          <a href="/fundraising/#contact" class="btn btn-primary">Volunteer with us</a>
        </div>
      </div>
    </section>
