---
layout: base.njk
---
    <!-- ======== SUPPORT HERO ======== -->
    <section class="hero">
      <div class="container">
        <h1>{{ hero_title }}</h1>
        <p class="tagline">{{ hero_tagline }}</p>
      </div>
    </section>

    <!-- ======== FOR PATIENTS & FAMILIES ======== -->
    <section class="section section--alt" id="patients">
      <div class="container">
        <div class="section__header">
          <h2>For Patients, Families &amp; People Trying to Conceive</h2>
          <p>{{ patients_intro }}</p>
        </div>

        <div class="two-col">
          <div>
            <p>While Fertility Research UK is not a clinical service, we aim to support patients by:</p>
            <ul style="padding-left:1.25rem; color:var(--muted); margin-top:0.75rem;">
              {% for item in patient_support %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
          <div>
            <div class="info-box">
              <p><strong>Need medical advice?</strong></p>
              <p>Please speak to your GP or fertility specialist.</p>
              <p class="mt-1"><strong>In urgent distress or crisis?</strong></p>
              <p>Contact <strong>NHS&nbsp;111</strong> (or <strong>999</strong> in an emergency).</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== FOR DONORS ======== -->
    <section class="section" id="donors">
      <div class="container">
        <div class="section__header">
          <h2>Your Donation Helps Fund Progress</h2>
          <p>{{ donors_intro }}</p>
        </div>

        <div class="card-grid card-grid--3" style="max-width:800px; margin:0 auto;">
          {% for card in donor_cards %}
          <div class="card">
            <div class="card__icon{% if loop.index0 % 2 == 1 %} card__icon--accent{% endif %}">{{ card.icon }}</div>
            <h3>{{ card.title }}</h3>
            <p>{{ card.description }}</p>
          </div>
          {% endfor %}
        </div>


      </div>
    </section>

    <!-- ======== CONTACT FORM ======== -->
    <section class="section section--alt" id="contact">
      <div class="container" style="max-width:640px;">
        <div class="section__header">
          <h2>Get in Touch</h2>
          <p>For governance, partnerships, volunteering, research enquiries or general questions.</p>
        </div>

        <form id="contact-form" action="https://formspree.io/f/xplaceholder" method="POST">
          <div class="form-group">
            <label for="contact-name">Your name</label>
            <input type="text" id="contact-name" name="name" required autocomplete="name">
          </div>

          <div class="form-group">
            <label for="contact-email">Email address</label>
            <input type="email" id="contact-email" name="email" required autocomplete="email">
          </div>

          <div class="form-group">
            <label for="contact-role">I am a…</label>
            <select id="contact-role" name="role">
              <option value="" disabled selected>Please select</option>
              {% for role in contact_roles %}
              <option value="{{ role.value }}">{{ role.label }}</option>
              {% endfor %}
            </select>
          </div>

          <div class="form-group">
            <label for="contact-message">Your message</label>
            <textarea id="contact-message" name="message" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%;">Send message</button>
        </form>

        <div id="form-success" class="form-success mt-3">
          <p><strong>Thank you!</strong> Your message has been sent. We'll be in touch soon.</p>
        </div>
      </div>
    </section>
