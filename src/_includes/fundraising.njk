---
layout: base.njk
---
    <!-- ======== HERO ======== -->
    <section class="hero">
      <div class="container">
        <h1>{{ hero_title | default("Fundraising") }}</h1>
        <p class="tagline">{{ hero_tagline | default("Help us fund the research that matters.") }}</p>
      </div>
    </section>

    <!-- ======== WHY FUND RESEARCH ======== -->
    <section class="section section--alt">
      <div class="container" style="max-width:800px;">
        <div class="section__header">
          <h2>Why Fund Fertility Research?</h2>
        </div>
        <p>Around 1 in 7 couples experience infertility, yet fertility research remains significantly underfunded compared with other areas of medicine. Better evidence leads to better diagnoses, more effective treatments, and fairer access to care.</p>
        <p class="mt-2">Funds raised by Fertility Research UK will support high-quality, independent research across the UK — from laboratory science to clinical trials to patient experience studies.</p>

        <div class="card-grid card-grid--3 mt-4">
          <div class="card card--cue">
            <h3>Fund Research</h3>
            <p>Support grants for scientists and clinicians working to improve fertility diagnosis, treatment, and prevention.</p>
          </div>
          <div class="card card--cue card--cue-accent">
            <h3>Drive Discovery</h3>
            <p>Enable the kind of independent, curiosity-driven research that leads to real breakthroughs in reproductive medicine.</p>
          </div>
          <div class="card card--cue">
            <h3>Change Lives</h3>
            <p>Help ensure that future patients have access to better information, more options, and improved outcomes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== WAYS TO GIVE ======== -->
    <section class="section">
      <div class="container" style="max-width:800px;">
        <div class="section__header">
          <h2>Ways to Give</h2>
          <p>We are preparing a range of ways for individuals and organisations to support our work.</p>
        </div>

        <div class="card-grid card-grid--2 mt-3">
          <div class="card card--cue">
            <h3>One-off Donation</h3>
            <p>Make a single gift of any amount to support our research programme. Online donations will be available once our charity registration is confirmed.</p>
          </div>
          <div class="card card--cue card--cue-accent">
            <h3>Regular Giving</h3>
            <p>A monthly or annual gift provides a reliable income that allows us to plan longer-term research funding. Standing order details coming soon.</p>
          </div>
          <div class="card card--cue">
            <h3>Legacy Giving</h3>
            <p>A gift in your will is one of the most significant contributions you can make. Contact us to discuss how a legacy gift can support fertility research for generations.</p>
          </div>
          <div class="card card--cue card--cue-accent">
            <h3>Corporate Partnerships</h3>
            <p>We welcome partnerships with companies that share our commitment to improving reproductive health. Sponsorship, matched giving, and cause-related programmes available.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== FUNDRAISE FOR US ======== -->
    <section class="section section--alt">
      <div class="container" style="max-width:800px;">
        <div class="section__header">
          <h2>Fundraise for Us</h2>
          <p>Take on a challenge or organise your own event to raise money for fertility research.</p>
        </div>

        <div class="card-grid card-grid--3 mt-3">
          <div class="card card--cue">
            <h3>Challenge Events</h3>
            <p>Marathons, bike rides, sponsored walks — take on a physical challenge and raise funds along the way.</p>
          </div>
          <div class="card card--cue card--cue-accent">
            <h3>Community Fundraising</h3>
            <p>Bake sales, quiz nights, dress-down days — every initiative makes a difference. We can provide materials and support.</p>
          </div>
          <div class="card card--cue">
            <h3>Birthday &amp; Celebration Giving</h3>
            <p>Ask friends and family to donate to FRUK instead of gifts for your birthday, wedding, or other milestone.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== GIFT AID ======== -->
    <section class="section">
      <div class="container" style="max-width:800px;">
        <div class="section__header">
          <h2>Gift Aid</h2>
        </div>
        <div class="card" style="border-left: 3px solid var(--accent);">
          <p><strong>If you are a UK taxpayer, Gift Aid increases the value of your donation by 25% at no extra cost to you.</strong></p>
          <p class="mt-2">For every £1 you donate, we can claim an extra 25p from HMRC. We will provide Gift Aid declaration forms once our charity registration is confirmed.</p>
        </div>
      </div>
    </section>

    <!-- ======== COMING SOON NOTICE ======== -->
    <section class="section section--alt">
      <div class="container text-center" style="max-width:700px;">
        <div style="background: var(--primary-light); border: 1px solid var(--primary); border-radius: var(--radius-lg); padding: 2.5rem 2rem;">
          <h2 style="color: var(--primary-dark); margin-bottom: 0.75rem;">Donations Opening Soon</h2>
          <p>We are currently completing our charity registration. Once confirmed, we will open online donations and publish our full funding programme.</p>
          <p class="mt-2">In the meantime, if you would like to discuss supporting our work — whether as an individual donor, corporate partner, or fundraiser — please get in touch.</p>
          <a href="#contact" class="btn btn-primary mt-3">Contact us</a>
        </div>
      </div>
    </section>

    <!-- ======== CONTACT FORM ======== -->
    <section class="section" id="contact">
      <div class="container" style="max-width:640px;">
        <div class="section__header">
          <h2>Get in Touch</h2>
          <p>For governance, partnerships, volunteering, research enquiries or general questions.</p>
        </div>

        <form id="contact-form" action="https://formspree.io/f/xwvaebjy" method="POST">
          <input type="hidden" name="_subject" value="Fertility Research UK — website contact form">
          <div class="form-group">
            <label for="contact-name">Your name</label>
            <input type="text" id="contact-name" name="name" required autocomplete="name">
          </div>

          <div class="form-group">
            <label for="contact-email">Email address</label>
            <input type="email" id="contact-email" name="email" required autocomplete="email">
          </div>

          <div class="form-group">
            <label for="contact-role">I am a…</label>
            <select id="contact-role" name="role">
              <option value="" disabled selected>Please select</option>
              {% for role in contact_roles %}
              <option value="{{ role.value }}">{{ role.label }}</option>
              {% endfor %}
            </select>
          </div>

          <div class="form-group">
            <label for="contact-message">Your message</label>
            <textarea id="contact-message" name="message" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%;">Send message</button>
        </form>

        <div id="form-success" class="form-success mt-3">
          <p><strong>Thank you!</strong> Your message has been sent. We'll be in touch soon.</p>
        </div>
      </div>
    </section>
