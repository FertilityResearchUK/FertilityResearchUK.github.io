---
layout: base.njk
---
    <!-- ======== HERO ======== -->
    <section class="hero hero--home">
      <div class="container">
        <h1>{{ hero_title }}</h1>
        <p class="tagline">{{ hero_tagline }}</p>
        <p class="lead">{{ hero_lead }}</p>
        <div class="hero-actions">
          <a href="/research/" class="btn btn-primary">Our research focus</a>
          <a href="/fundraising/" class="btn btn-secondary">Support our work</a>
        </div>
      </div>
    </section>

    <!-- ======== OUR PURPOSE ======== -->
    <section class="section section--alt" id="purpose">
      <div class="container">
        <div class="section__header">
          <h2>Our Purpose</h2>
          <p>{{ purpose_intro }}</p>
          <p class="mt-2">{{ purpose_mission }}</p>
        </div>

        <!-- Did you know? callouts -->
        <div class="card-grid card-grid--3">
          {% for item in callouts %}
          <div class="callout">
            <p><strong>Did you know?</strong> {{ item }}</p>
          </div>
          {% endfor %}
        </div>

        <div class="text-center mt-4" style="max-width:720px; margin-left:auto; margin-right:auto;">
          {{ content | safe }}
        </div>
      </div>
    </section>

    <!-- decorative image -->
    <div class="image-inset mt-4 mb-3" aria-hidden="true">
      <img src="/assets/stock-review/01-scientist-microscope-lab.jpg" alt="" loading="lazy">
    </div>

    <!-- ======== WHAT WE DO ======== -->
    <section class="section" id="what-we-do">
      <div class="container">
        <div class="section__header">
          <h2>What We Do</h2>
          <p>Six areas of focus for patients, researchers and the wider community.</p>
        </div>

        <div class="card-grid card-grid--3">
          {% for card in what_we_do %}
          <div class="card card--cue{% if loop.index0 % 2 == 1 %} card--cue-accent{% endif %}">
            <h3>{{ card.title }}</h3>
            <p>{{ card.description }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <!-- ======== LATEST NEWS ======== -->
    {% if collections.news.length %}
    <section class="section section--alt" id="news">
      <div class="container">
        <div class="section__header">
          <h2>Latest News</h2>
          <p>Updates from Fertility Research UK.</p>
        </div>

        <div class="card-grid card-grid--3">
          {% for post in collections.news | reverse %}
          {% if loop.index <= 3 %}
          <article class="news-card">
            {% if post.data.image %}
            <div class="news-card__image">
              <img src="{{ post.data.image }}" alt="" loading="lazy">
            </div>
            {% endif %}
            <time class="news-card__date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
            <h3>{{ post.data.headline }}</h3>
            <p>{{ post.data.summary }}</p>
          </article>
          {% endif %}
          {% endfor %}
        </div>

        <div class="text-center mt-4">
          <a href="/news/" class="btn btn-secondary">All news &amp; updates</a>
        </div>
      </div>
    </section>
    {% endif %}
