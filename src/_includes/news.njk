---
layout: base.njk
---
    <!-- ======== NEWS HERO ======== -->
    <section class="hero">
      <div class="container">
        <h1>{{ hero_title | default("News & Updates") }}</h1>
        <p class="tagline">{{ hero_tagline | default("Announcements, updates and progress from Fertility Research UK.") }}</p>
      </div>
    </section>

    <!-- ======== NEWS LIST ======== -->
    <section class="section section--alt">
      <div class="container" style="max-width:800px;">
        {% for post in collections.news | reverse %}
        <article class="news-item">
          {% if post.data.image %}
          <div class="news-item__image">
            <img src="{{ post.data.image }}" alt="" loading="lazy">
          </div>
          {% endif %}
          <time class="news-item__date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
          <h2 class="news-item__headline">{{ post.data.headline }}</h2>
          <div class="news-item__body">
            {{ post.templateContent | safe }}
          </div>
        </article>
        {% endfor %}

        {% if not collections.news.length %}
        <div class="text-center text-muted">
          <p>No news yet — check back soon.</p>
        </div>
        {% endif %}
      </div>
    </section>
